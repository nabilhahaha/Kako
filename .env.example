NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Error monitoring (Sentry) — optional. Leave empty to disable; error capture is
# a no-op until a DSN is set. Get the DSN from your Sentry project settings.
NEXT_PUBLIC_SENTRY_DSN=

# Only needed to upload source maps for readable stack traces (set in the build
# environment, e.g. the hosting provider). Safe to leave empty.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Integration tests against a disposable Postgres (see docs/TESTING.md). Leave
# empty to skip them.
TEST_DATABASE_URL=
