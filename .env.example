NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Error monitoring (Sentry) — optional. Leave empty to disable; error capture is
# a no-op until a DSN is set. Get the DSN from your Sentry project settings.
# Set this in BOTH the build env and the runtime env (it's a public DSN).
NEXT_PUBLIC_SENTRY_DSN=

# Optional Sentry tuning (sensible defaults applied if unset):
#   *_ENVIRONMENT   override the auto-detected env (production/preview/development)
#   *_TRACES_SAMPLE_RATE   performance sampling 0..1 (default 0.1)
#   NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR   session-replay-on-error 0..1 (default 0)
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR=

# Only needed to upload source maps for readable stack traces (set in the build
# environment, e.g. the hosting provider). Safe to leave empty.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Integration tests against a disposable Postgres (see docs/TESTING.md). Leave
# empty to skip them.
TEST_DATABASE_URL=

# ── Egyptian e-invoicing (ETA) — see docs/ETA.md ──
# Inert until client credentials are set. Use "preprod" until accredited.
ETA_ENVIRONMENT=preprod
ETA_CLIENT_ID=
ETA_CLIENT_SECRET=
ETA_DOCUMENT_TYPE_VERSION=1.0
# e-seal signing service (local token agent / HSM front) that turns the
# canonical document into a CAdES-BES signature. Submission is refused until set.
ETA_SIGNING_URL=
ETA_SIGNING_TOKEN=

# ── Staging / backups (CI secrets — see docs/STAGING.md & docs/BACKUPS.md) ──
# Postgres connection strings (use the Supabase "session" pooler URI, sslmode=require).
STAGING_DATABASE_URL=
PRODUCTION_DATABASE_URL=
# Where scheduled pg_dump backups are uploaded (S3-compatible). Optional — if
# unset, the backup workflow keeps the dump as a short-retention CI artifact.
BACKUP_S3_BUCKET=
BACKUP_S3_ENDPOINT=
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
# Optional GPG public key (armored) to encrypt dumps at rest.
BACKUP_GPG_PUBLIC_KEY=
