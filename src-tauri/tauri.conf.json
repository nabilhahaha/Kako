{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VANTORA",
  "version": "0.1.0-beta.1",
  "identifier": "com.vantora.offline",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "shell",
    "devUrl": "http://127.0.0.1:54331"
  },
  "app": {
    "windows": [
      {
        "title": "VANTORA",
        "url": "http://127.0.0.1:54331",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "tooltip": "VANTORA"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/postgres",
      "binaries/postgrest",
      "binaries/node"
    ],
    "resources": [
      "resources/migrations/**",
      "resources/postgrest.conf.template"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/nabilhahaha/Kako/releases/download/updates-stable/latest-{{target}}-{{arch}}.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2NEQ5Q0Q0RkE1RUQ3NEYKUldSUDExNzYxSnhORnJLSFhvSXh1SDM1bkxENmxDZEVlNkU3RzQydnVJTTArSDBBT1lQT2psVm8K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
