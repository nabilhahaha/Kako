# SalesBook — environment configuration
# Copy to .env.local and fill in for a production backend. With NONE of these
# set, the app runs fully on the dependency-free file store (default).

# ---- Persistence backend ---------------------------------------------------
# file (default) | supabase
DATA_BACKEND=file

# ---- File storage backend --------------------------------------------------
# local (default) | supabase | s3
STORAGE_BACKEND=local
SUPABASE_STORAGE_BUCKET=salesbook

# ---- Auth provider ---------------------------------------------------------
# demo (default) | supabase
AUTH_PROVIDER=demo

# ---- Supabase (required when DATA_BACKEND/STORAGE_BACKEND/AUTH_PROVIDER=supabase)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
